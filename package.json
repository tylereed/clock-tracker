{
  "name": "clock-tracker",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "antlr4-generate": "antlr4 -Dlanguage=TypeScript -lib grammars -o src/generated/parsers grammars/Roll.g4 grammars/Attack.g4"
  },
  "dependencies": {
    "@mdi/font": "7.4.47",
    "@vueuse/core": "^14.2.1",
    "antlr4": "4.13.2",
    "debounce": "^3.0.0",
    "luxon": "^3.7.2",
    "pinia": "^3.0.4",
    "pluralize": "^8.0.0",
    "roboto-fontface": "0.10.0",
    "typo-js": "^1.3.1",
    "vue": "^3.5.33",
    "vuetify": "^4.0.6"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@pinia/testing": "^1.0.3",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/pluralize": "^0.0.33",
    "@types/typo-js": "^1.2.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "canvas": "^3.2.3",
    "jsdom": "^29.0.2",
    "resize-observer-polyfill": "^1.5.1",
    "typescript": "^6.0.3",
    "unplugin-fonts": "^2.0.0",
    "vite": "^8.0.10",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
